<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="ulixhand">

    <!-- run: xacro ulixarm.urdf > ulixarm.xacro -->
    
    <!-- CONSTANTS -->

    <xacro:property name="PI" value="3.14159265359"/>
    <xacro:property name="velocity_limit_DMJ3507"   value="15.0"/>
    <xacro:property name="effort_limit_DMJ3507"     value="3.0"/>

    <!-- LINKS -->
    
    <link name="base_link">
        <visual>
            <origin xyz="0. 0. 0."/>
            <geometry>
                <mesh filename="package://ulixarm_description/meshes/visual/gripper_base.stl"/>
            </geometry>
        </visual>
        <collision>
            <origin xyz="0. 0. 0."/>
            <geometry>
                <mesh filename="package://ulixarm_description/meshes/collision/gripper_base.stl"/>
            </geometry>
        </collision>
    </link>

    <link name="finger_right">
        <visual>
            <origin xyz="0. 0. 0."/>
            <geometry>
                <mesh filename="package://ulixarm_description/meshes/visual/finger.stl"/>
            </geometry>
        </visual>
        <collision>
            <origin xyz="0. 0. 0."/>
            <geometry>
                <mesh filename="package://ulixarm_description/meshes/collision/finger.stl"/>
            </geometry>
        </collision>
        <inertial>
            <mass value="1.0"/>
            <inertia ixx="1.0" ixy="0.0" ixz="0.0" iyy="1.0" iyz="0.0" izz="1.0"/>
        </inertial>
    </link>

    <link name="finger_left">
        <visual>
            <origin xyz="0. 0. 0."/>
            <geometry>
                <mesh filename="package://ulixarm_description/meshes/visual/finger.stl"/>
            </geometry>
        </visual>
        <collision>
            <origin xyz="0. 0. 0."/>
            <geometry>
                <mesh filename="package://ulixarm_description/meshes/collision/finger.stl"/>
            </geometry>
        </collision>
        <inertial>
            <mass value="1.0"/>
            <inertia ixx="1.0" ixy="0.0" ixz="0.0" iyy="1.0" iyz="0.0" izz="1.0"/>
        </inertial>
    </link>


    <!-- JOINTS -->

    <joint name="finger_right_joint" type="prismatic">
        <origin xyz="0. 0. 0.1219" rpy="0. 0. 0."/>
        <parent link="base_link"/>
        <child link="finger_right"/>
        <axis xyz="1 0 0"/>
        <limit lower="0" upper="0.05" velocity="${velocity_limit_DMJ3507}" effort="${effort_limit_DMJ3507}"/> 
    </joint>

    <joint name="finger_left_joint" type="prismatic">
        <origin xyz="0. 0. 0.1219" rpy="0. 0. 0."/>
        <parent link="base_link"/>
        <child link="finger_left"/>
        <axis xyz="1 0 0"/>
        <mimic joint="finger_right_joint" multiplier="-1" offset="0"/>
        <limit lower="0" upper="0.05" velocity="${velocity_limit_DMJ3507}" effort="${effort_limit_DMJ3507}"/> 
    </joint>

</robot>
