<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

    <xacro:macro name="manipulator_macro" params="prefix">

        <!-- CONSTANTS -->

        <xacro:property name="PI" value="3.14159265359"/>
        <xacro:property name="velocity_limit_DM4340"   value="8.0"/>
        <xacro:property name="effort_limit_DM4340"  value="27.0"/>
        <xacro:property name="velocity_limit_DM4310"   value="30.0"/>
        <xacro:property name="effort_limit_DM4310"  value="10.0"/>

        <!-- LINKS -->
        
        <link name="${prefix}base_link">
            <visual>
                <origin xyz="0. 0. 0."/>
                <geometry>
                    <mesh filename="package://ulixarm_description/meshes/visual/base_link.dae"/>
                </geometry>
            </visual>
            <collision>
                <origin xyz="0. 0. 0."/>
                <geometry>
                    <mesh filename="package://ulixarm_description/meshes/collision/base_link.stl"/>
                </geometry>
            </collision>
            <!-- <inertial>
                <origin xyz="0. 0. 0."/>
                <mass value="0.0001"/>
                <inertia ixx="0.0001" ixy="0.0" ixz="0.0" iyy="0.0001" iyz="0.0" izz="0.0001"/>
            </inertial> -->
        </link>

        <link name="${prefix}link1">
            <visual>
                <origin xyz="0. 0. 0."/>
                <geometry>
                    <mesh filename="package://ulixarm_description/meshes/visual/link1.dae"/>
                </geometry>
            </visual>
            <collision>
                <origin xyz="0. 0. 0."/>
                <geometry>
                    <mesh filename="package://ulixarm_description/meshes/collision/link1.stl"/>
                </geometry>
            </collision>
            <inertial>
                <origin xyz="0. 0. 0.037"/>
                <mass value="0.480"/>
                <inertia ixx="0.0001" ixy="0.0" ixz="0.0" iyy="0.0001" iyz="0.0" izz="0.0001"/>
            </inertial>
        </link>

        <link name="${prefix}link2">
            <visual>
                <origin xyz="0. 0. 0."/>
                <geometry>
                    <mesh filename="package://ulixarm_description/meshes/visual/link2.dae"/>
                </geometry>
            </visual>
            <collision>
                <origin xyz="0. 0. 0."/>
                <geometry>
                    <mesh filename="package://ulixarm_description/meshes/collision/link2.stl"/>
                </geometry>
            </collision>
            <inertial>
                <origin xyz="0.197 0. -0.004"/>
                <mass value="0.690"/>
                <inertia ixx="0.0001" ixy="0.0" ixz="0.0" iyy="0.0001" iyz="0.0" izz="0.0001"/>
            </inertial>
        </link>

        <link name="${prefix}link3">
            <visual>
                <origin xyz="0. 0. 0."/>
                <geometry>
                    <mesh filename="package://ulixarm_description/meshes/visual/link3.dae"/>
                </geometry>
            </visual>
            <collision>
                <origin xyz="0. 0. 0."/>
                <geometry>
                    <mesh filename="package://ulixarm_description/meshes/collision/link3.stl"/>
                </geometry>
            </collision>
            <inertial>
                <origin xyz="0.197 0. -0.004"/>
                <mass value="0.680"/>
                <!-- <mass value="0.690"/> -->
                <inertia ixx="0.0001" ixy="0.0" ixz="0.0" iyy="0.0001" iyz="0.0" izz="0.0001"/>
            </inertial>
        </link>

        <link name="${prefix}link4">
            <visual>
                <origin xyz="0. 0. 0."/>
                <geometry>
                    <mesh filename="package://ulixarm_description/meshes/visual/link4.dae"/>
                </geometry>
            </visual>
            <collision>
                <origin xyz="0. 0. 0."/>
                <geometry>
                    <mesh filename="package://ulixarm_description/meshes/collision/link4.stl"/>
                </geometry>
            </collision>
            <inertial>
                <origin xyz="0.022 0.0 0.018"/>
                <!-- <mass value="0.100"/> -->
                <mass value="0.100"/>
                <inertia ixx="0.0001" ixy="0.0" ixz="0.0" iyy="0.0001" iyz="0.0" izz="0.0001"/>
            </inertial>
        </link>

        <link name="${prefix}link5">
            <visual>
                <origin xyz="0. 0. 0."/>
                <geometry>
                    <mesh filename="package://ulixarm_description/meshes/visual/link5.dae"/>
                </geometry>
            </visual>
            <collision>
                <origin xyz="0. 0. 0."/>
                <geometry>
                    <mesh filename="package://ulixarm_description/meshes/collision/link5.stl"/>
                </geometry>
            </collision>
            <inertial>
                <origin xyz="0.030 0.0 -0.023"/>
                <!-- <mass value="0.700"/> -->
                <mass value="0.700"/>
                <inertia ixx="0.0001" ixy="0.0" ixz="0.0" iyy="0.0001" iyz="0.0" izz="0.0001"/>
            </inertial>
        </link>

        <link name="${prefix}link6">
            <inertial>
                <origin xyz="0. 0. 0."/>
                <mass value="0.001"/>
                <inertia ixx="0.0001" ixy="0.0" ixz="0.0" iyy="0.0001" iyz="0.0" izz="0.0001"/>
            </inertial>
        </link>

        <link name="${prefix}tool0">
            <inertial>
                <origin xyz="0. 0. 0."/>
                <mass value="0.001"/>
                <inertia ixx="0.0001" ixy="0.0" ixz="0.0" iyy="0.0001" iyz="0.0" izz="0.0001"/>
            </inertial>
        </link>


        <!-- JOINTS -->

        <joint name="joint1" type="revolute">
            <origin xyz="0. 0. 0.0533" rpy="0. 0. 0."/>
            <parent link="${prefix}base_link"/>
            <child link="${prefix}link1"/>
            <axis xyz="0 0 1"/>
            <limit lower="${-PI/2}" upper="${PI/2}" velocity="${velocity_limit_DM4340}" effort="${effort_limit_DM4340}"/> 
        </joint>

        <joint name="joint2" type="revolute">
            <origin xyz="0.027175 0. 0.0425" rpy="${PI} ${-PI/2} 0."/>
            <parent link="${prefix}link1"/>
            <child link="${prefix}link2"/>
            <axis xyz="0 0 1"/>
            <limit lower="${-PI/2}" upper="${PI/2}" velocity="${velocity_limit_DM4340}" effort="${effort_limit_DM4340}"/> 
        </joint>

        <joint name="joint3" type="revolute">
            <origin xyz="0.280 0. -0.0473" rpy="${PI} 0. 0."/>
            <parent link="${prefix}link2"/>
            <child link="${prefix}link3"/>
            <axis xyz="0 0 1"/>
            <limit lower="${-PI/2}" upper="2.7925268" velocity="${velocity_limit_DM4340}" effort="${effort_limit_DM4340}"/> 
        </joint>

        <joint name="joint4" type="revolute">
            <origin xyz="0.260 0. -0.040" rpy="${PI} 0. ${-PI/2}"/>
            <parent link="${prefix}link3"/>
            <child link="${prefix}link4"/>
            <axis xyz="0 0 1"/>
            <limit lower="${-PI}" upper="${PI/2}" velocity="${velocity_limit_DM4310}" effort="${effort_limit_DM4310}"/> 
        </joint>

        <joint name="joint5" type="revolute">
            <origin xyz="0.046 0. 0.031" rpy="${PI/2} 0. ${-PI/2}"/>
            <parent link="${prefix}link4"/>
            <child link="${prefix}link5"/>
            <axis xyz="0 0 -1"/>
            <limit lower="${-PI/2}" upper="${PI/2}" velocity="${velocity_limit_DM4310}" effort="${effort_limit_DM4310}"/> 
        </joint>

        <joint name="joint6" type="revolute">
            <origin xyz="0.0825 0. -0.0235" rpy="${PI/2} 0. ${PI/2}"/>
            <parent link="${prefix}link5"/>
            <child link="${prefix}link6"/>
            <axis xyz="0 0 1"/>
            <limit lower="${-PI/2}" upper="${PI/2}" velocity="${velocity_limit_DM4310}" effort="${effort_limit_DM4310}"/> 
        </joint>

        <joint name="joint_tool0" type="fixed">
            <parent link="${prefix}link6"/>
            <child link="${prefix}tool0"/>
        </joint>

    </xacro:macro>

</robot>
