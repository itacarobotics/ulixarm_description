<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

    <xacro:macro name="gripper_macro" params="prefix">
        
        <!-- CONSTANTS -->

        <xacro:property name="PI" value="3.14159265359"/>
        <xacro:property name="velocity_limit_DMJ3507"   value="0.5"/>
        <xacro:property name="effort_limit_DMJ3507"     value="0.1"/>

        <!-- LINKS -->
        
        <link name="${prefix}base_link">
            <visual>
                <origin xyz="0. 0. 0."/>
                <geometry>
                    <mesh filename="package://ulixarm_description/meshes/visual/gripper_base.stl"/>
                </geometry>
            </visual>
            <collision>
                <origin xyz="0. 0. 0."/>
                <geometry>
                    <mesh filename="package://ulixarm_description/meshes/collision/gripper_base.stl"/>
                </geometry>
            </collision>
            <inertial>
                <mass value="1.0"/>
                <inertia ixx="1.0" ixy="0.0" ixz="0.0" iyy="1.0" iyz="0.0" izz="1.0"/>
            </inertial>
        </link>

        <link name="${prefix}finger_right">
            <visual>
                <origin xyz="0. 0. 0."/>
                <geometry>
                    <mesh filename="package://ulixarm_description/meshes/visual/finger.stl"/>
                </geometry>
            </visual>
            <collision>
                <origin xyz="0. 0. 0."/>
                <geometry>
                    <mesh filename="package://ulixarm_description/meshes/collision/finger.stl"/>
                </geometry>
            </collision>
            <inertial>
                <mass value="1.0"/>
                <inertia ixx="1.0" ixy="0.0" ixz="0.0" iyy="1.0" iyz="0.0" izz="1.0"/>
            </inertial>
        </link>

        <link name="${prefix}finger_left">
            <visual>
                <origin xyz="0. 0. 0."/>
                <geometry>
                    <mesh filename="package://ulixarm_description/meshes/visual/finger.stl"/>
                </geometry>
            </visual>
            <collision>
                <origin xyz="0. 0. 0."/>
                <geometry>
                    <mesh filename="package://ulixarm_description/meshes/collision/finger.stl"/>
                </geometry>
            </collision>
            <inertial>
                <mass value="1.0"/>
                <inertia ixx="1.0" ixy="0.0" ixz="0.0" iyy="1.0" iyz="0.0" izz="1.0"/>
            </inertial>
        </link>


        <!-- JOINTS -->

        <joint name="finger_right_joint" type="prismatic">
            <origin xyz="0. 0. 0.1349" rpy="0. 0. 0."/>
            <parent link="${prefix}base_link"/>
            <child link="${prefix}finger_right"/>
            <axis xyz="1 0 0"/>
            <limit lower="-0.05" upper="0.038" velocity="${velocity_limit_DMJ3507}" effort="${effort_limit_DMJ3507}"/> 
        </joint>

        <joint name="finger_left_joint" type="prismatic">
            <origin xyz="0. 0. 0.1349" rpy="0. 0. ${PI}"/>
            <parent link="${prefix}base_link"/>
            <child link="${prefix}finger_left"/>
            <axis xyz="-1 0 0"/>
            <mimic joint="finger_right_joint" multiplier="-1" offset="0"/>
            <limit lower="-0.038" upper="0.05" velocity="${velocity_limit_DMJ3507}" effort="${effort_limit_DMJ3507}"/> 
        </joint>
  
  </xacro:macro>

</robot>
