<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

    <xacro:macro name="gripper_macro" params="prefix">
        
        <!-- CONSTANTS -->

        <xacro:property name="PI" value="3.14159265359"/>
        <xacro:property name="velocity_limit_DMJ3507"   value="0.5"/>
        <xacro:property name="effort_limit_DMJ3507"     value="0.1"/>

        <!-- LINKS -->
        
        <link name="${prefix}base_link">
            <visual>
                <origin xyz="0. 0. 0."/>
                <geometry>
                    <mesh filename="package://ulixarm_description/meshes/visual/gripper_base_link.dae"/>
                </geometry>
            </visual>
            <collision>
                <origin xyz="0. 0. 0."/>
                <geometry>
                    <mesh filename="package://ulixarm_description/meshes/collision/gripper_base_link.stl"/>
                </geometry>
            </collision>
            <inertial>
                <origin xyz="0. 0. 0.052"/>
                <mass value="0.450"/>
                <inertia ixx="0.0001" ixy="0.0" ixz="0.0" iyy="0.0001" iyz="0.0" izz="0.0001"/>
            </inertial>
        </link>

        <link name="${prefix}finger_right">
            <visual>
                <origin xyz="0. 0. 0."/>
                <geometry>
                    <mesh filename="package://ulixarm_description/meshes/visual/finger_right.dae"/>
                </geometry>
            </visual>
            <collision>
                <origin xyz="0. 0. 0."/>
                <geometry>
                    <mesh filename="package://ulixarm_description/meshes/collision/finger_right.stl"/>
                </geometry>
            </collision>
            <inertial>
                <origin xyz="0.008 0.002 -0.052"/>
                <mass value="0.075"/>
                <inertia ixx="0.0001" ixy="0.0" ixz="0.0" iyy="0.0001" iyz="0.0" izz="0.0001"/>
            </inertial>
        </link>

        <link name="${prefix}finger_left">
            <visual>
                <origin xyz="0. 0. 0."/>
                <geometry>
                    <mesh filename="package://ulixarm_description/meshes/visual/finger_right.dae"/>
                </geometry>
            </visual>
            <collision>
                <origin xyz="0. 0. 0."/>
                <geometry>
                    <mesh filename="package://ulixarm_description/meshes/collision/finger_right.stl"/>
                </geometry>
            </collision>
            <inertial>
                <origin xyz="0.008 0.002 -0.052"/>
                <mass value="0.075"/>
                <inertia ixx="0.0001" ixy="0.0" ixz="0.0" iyy="0.0001" iyz="0.0" izz="0.0001"/>
            </inertial>
        </link>


        <!-- JOINTS -->

        <joint name="finger_right_joint" type="prismatic">
            <origin xyz="0. 0. 0.1289" rpy="0. 0. 0."/>
            <parent link="${prefix}base_link"/>
            <child link="${prefix}finger_right"/>
            <axis xyz="1 0 0"/>
            <limit lower="0.0" upper="0.04" velocity="${velocity_limit_DMJ3507}" effort="${effort_limit_DMJ3507}"/> 
        </joint>

        <joint name="finger_left_joint" type="prismatic">
            <origin xyz="0. 0. 0.1289" rpy="0. 0. ${PI}"/>
            <parent link="${prefix}base_link"/>
            <child link="${prefix}finger_left"/>
            <axis xyz="1 0 0"/>
            <mimic joint="finger_right_joint" multiplier="1" offset="0"/>
            <limit lower="0.0" upper="0.04" velocity="${velocity_limit_DMJ3507}" effort="${effort_limit_DMJ3507}"/> 
        </joint>
  
  </xacro:macro>

</robot>
